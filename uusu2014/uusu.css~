/* General styles */
a {color:#990000; text-decoration:none; font-weight:400;}
a:hover {text-decoration:underline;}
p,ul,ol,dl {margin:0 0 10px 0; line-height:1.5em;}
h1 {color:#990000; font-size:3.6em; margin-bottom:0;}
h2 {font-size:2.2em; color:#990000; margin-top:25px;margin-bottom:25px}
h3 {font-size:1.6em; margin-bottom:12px;}
h1,h2,h3 {color:#990000; font-weight:400; line-height:1.2em; font-family:'Ubuntu', sans-serif;}

body {font-family: 'Ubuntu', sans-serif;}

